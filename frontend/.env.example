# Frontend public env vars (safe to expose in client bundle)
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Pandemonium NFT contract address on Sepolia
NEXT_PUBLIC_PANDEMONIUM_ADDRESS=0xYourPandemoniumContractAddress

# Optional alias supported by the app
# NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0xYourPandemoniumContractAddress

# Server-only API key used by Next API routes (do not prefix with NEXT_PUBLIC_)
ALCHEMY_API_KEY=your_server_side_alchemy_api_key
